# Required: shared secret for WebSocket and HTTP auth
WEBAPP_AUTH_TOKEN=change-me-to-a-long-random-token

# Absolute path to the workspace the app-server operates on
WORKSPACE_ROOT=/absolute/path/to/workspace

# Command used to launch the app-server (spaces OK — first token is the binary)
CODEX_APP_SERVER_CMD=codex app-server
CODEX_APP_SERVER_ARGS=

# HTTP port (default: 3000)
PORT=3000

# Max size in bytes for WebSocket payloads and app-server JSONL lines (default: 256000)
MAX_MSG_BYTES=256000

# Max queued messages to the app-server before rejecting (default: 200)
MAX_QUEUE=200

# Kill idle app-server sessions after this many milliseconds (default: 600000 = 10 min)
KILL_IDLE_MS=600000

# Optional: write a raw JSONL "wire log" to session.log (disabled by default)
SESSION_LOG=0

# Optional: WS ticket TTL in ms for browser clients (default: 120000)
WS_TICKET_TTL_MS=120000
